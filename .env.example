
# ============================================================
# Digital Financial Literacy Agent - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================================

# ── Flask Configuration ──────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ── IBM Watsonx.ai Configuration ─────────────────────────────
IBM_CLOUD_API_KEY=your-ibm-cloud-api-key-here
IBM_WATSONX_PROJECT_ID=your-watsonx-project-id-here
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── IBM Granite Model IDs ─────────────────────────────────────
GRANITE_CHAT_MODEL=ibm/granite-3-8b-instruct
GRANITE_EMBEDDING_MODEL=ibm/slate-125m-english-rtrvr

# ── Database Configuration ────────────────────────────────────
DATABASE_URL=sqlite:///instance/finliteracy.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/finliteracy

# ── Vector Database (ChromaDB) ────────────────────────────────
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=financial_knowledge

# ── RAG Configuration ─────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.7
MAX_RESPONSE_TOKENS=1024
MAX_CHAT_HISTORY_TURNS=6

# ── File Upload Configuration ─────────────────────────────────
UPLOAD_FOLDER=data/uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,csv

# ── Session Configuration ─────────────────────────────────────
SESSION_TYPE=filesystem
SESSION_LIFETIME_HOURS=24
PERMANENT_SESSION_LIFETIME=86400

# ── Email Configuration (Optional) ───────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Admin Configuration ───────────────────────────────────────
ADMIN_EMAIL=REDACTED_EMAIL
ADMIN_PASSWORD=REDACTED_PASSWORD
ADMIN_NAME=System Admin

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# ── Feature Flags ─────────────────────────────────────────────
ENABLE_VOICE_ASSISTANT=True
ENABLE_MULTILINGUAL=True
ENABLE_RAG=True
ENABLE_ANALYTICS=True
ENABLE_CERTIFICATES=True

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
